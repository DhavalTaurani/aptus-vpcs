        <!-- Accommodation Expense -->
        <record id="pl_ae_line" model="account.report.line">
            <field name="name">Accommodation Expense</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">23</field>
