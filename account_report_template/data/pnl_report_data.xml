<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Account Report Template -->
        <record id="account_report_template_pl" model="account.report">
            <field name="name">Profit Loss Report Template</field>
        </record>

        <function name="unlink" model="account.report.line">
            <value model="account.report.line" eval="obj().search([('report_id', '=', ref('account_report_template.account_report_template_pl')), ('code', 'in', ['TR', 'TCOGS', 'GROSS', 'PRR', 'ADJP', 'MAXREM', 'ALRM', 'TAXINC', 'TTXLB'])]).ids"/>
        </function>

        <!-- Income -->
        <record id="pl_income_line" model="account.report.line">
            <field name="name">Income</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">1</field>
            <field name="code">INCOME</field>
        </record>

         <!-- Operating Revenue -->
        <record id="pl_operating_revenue_line" model="account.report.line">
            <field name="name">Operating Revenue</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">2</field>
            <field name="hierarchy_level">3</field>
            <field name="code">OR</field>
        </record>

        <!-- Product Sales -->
        <record id="pl_product_sales_line" model="account.report.line">
            <field name="name">Product Sales</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">3</field>
            <field name="hierarchy_level">5</field>
            <field name="code">PS</field>
        </record>

        <!-- Product Sales Expression -->
        <record id="product_sales_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'PS')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_product_sales_line"/>
        </record>

        <!-- Service Revenue -->
        <record id="pl_service_revenue_line" model="account.report.line">
            <field name="name">Service Revenue</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">4</field>
            <field name="hierarchy_level">5</field>
            <field name="code">SR</field>
        </record>

        <!-- Service Revenue Expression -->
        <record id="service_revenue_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'SR')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_service_revenue_line"/>
        </record>

        <!-- Contract Revenue -->
        <record id="pl_contract_revenue_line" model="account.report.line">
            <field name="name">Contract Revenue</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">5</field>
            <field name="hierarchy_level">5</field>
            <field name="code">CR</field>
        </record>

        <record id="contract_revenue_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'CR')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_contract_revenue_line"/>
        </record>

        <!-- Rental Income -->
        <record id="pl_rental_income_line" model="account.report.line">
            <field name="name">Rental Income</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">5</field>
            <field name="hierarchy_level">5</field>
            <field name="code">RI</field>
        </record>

        <record id="rental_income_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'RI')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_rental_income_line"/>
        </record>

        <!-- Commission Income -->
        <record id="pl_comission_income_line" model="account.report.line">
            <field name="name">Commission Income</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">6</field>
            <field name="hierarchy_level">5</field>
            <field name="code">CI</field>
        </record>

        <record id="commission_income_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'CI')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_comission_income_line"/>
        </record>

        <!-- Other Income -->
        <record id="pl_other_income_line" model="account.report.line">
            <field name="name">Other Income</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">7</field>
            <field name="hierarchy_level">3</field>
            <field name="code">OI</field>
        </record>

        <!-- Interest Income -->
        <record id="pl_interest_income_line" model="account.report.line">
            <field name="name">Interest Income</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">8</field>
            <field name="hierarchy_level">5</field>
            <field name="code">II</field>
        </record>

        <!-- Other Income Expression -->
        <record id="interest_income_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'II')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_interest_income_line"/>
        </record>

        <!-- Total Revenue -->
        <record id="pl_total_revenue_line" model="account.report.line">
            <field name="name">Total Revenue</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">8</field>
            <field name="hierarchy_level">5</field>
            <field name="code">TR</field>
        </record>

        <record id="total_revenue_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">aggregation</field>
            <field name="formula">PS.balance+SR.balance+CR.balance+RI.balance+CI.balance</field>
            <field name="report_line_id" ref="pl_total_revenue_line"/>
        </record>


        
        <!-- Foreign Exchange Gain -->
        <record id="pl_foreign_exc_gain_line" model="account.report.line">
            <field name="name">Foreign Exchange Gain</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">9</field>
            <field name="hierarchy_level">5</field>
            <field name="code">FEG</field>
        </record>

        <record id="foreign_exc_gain_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'FEG')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_foreign_exc_gain_line"/>
        </record>

        <!-- Gain on Asset Disposal -->
        <record id="pl_gain_assets_disposal_line" model="account.report.line">
            <field name="name">Gain on Asset Disposal</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">10</field>
            <field name="hierarchy_level">5</field>
            <field name="code">GAD</field>
        </record>

        <record id="gain_assets_disposal_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'GAD')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_gain_assets_disposal_line"/>
        </record>

        <!-- Other Non-operating Income -->
        <record id="pl_other_non_op_income_line" model="account.report.line">
            <field name="name">Other Non-operating Income</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">11</field>
            <field name="hierarchy_level">5</field>
            <field name="code">ONI</field>
        </record>

        <record id="other_non_op_income_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'ONI')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_other_non_op_income_line"/>
        </record>

        <!-- Dividend Income -->
        <record id="pl_dividend_income_line" model="account.report.line">
            <field name="name">Dividend Income</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">12</field>
            <field name="hierarchy_level">5</field>
            <field name="code">DI</field>
        </record>

        <record id="dividend_income_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'DI_PL')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_dividend_income_line"/>
        </record>

        <!-- Miscellaneous Income -->
        <record id="pl_miscellaneous_income_line" model="account.report.line">
            <field name="name">Miscellaneous Income</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">13</field>
            <field name="hierarchy_level">5</field>
            <field name="code">MI</field>
        </record>

        <record id="miscellaneous_income_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'MI')]</field>
            <field name="subformula">-sum</field>
            <field name="report_line_id" ref="pl_miscellaneous_income_line"/>
        </record>


        <!-- Total COGS -->
        <record id="pl_total_cogs_line" model="account.report.line">
            <field name="name">Total COGS</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">14</field>
            <field name="hierarchy_level">5</field>
            <field name="code">TCOGS</field>
        </record>

        <record id="total_cogs_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">aggregation</field>
            <field name="formula">PURCHASE.balance + DE.balance + CS.balance + CGST.balance</field>
            <field name="report_line_id" ref="pl_total_cogs_line"/>
        </record>

        <!-- Total Income -->
        <record id="pl_total_income_line" model="account.report.line">
            <field name="name">Total Income</field>
            <!-- <field name="user_groupby">account_id</field> -->
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">14</field>
            <field name="hierarchy_level">3</field>
            <field name="code">TI</field>
        </record>

        <record id="total_income_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">aggregation</field>
            <field name="formula">PS.balance + SR.balance + CR.balance + RI.balance + CI.balance + II.balance + FEG.balance + GAD.balance + ONI.balance + DI.balance + MI.balance</field>
            <!-- <field name="subformula">sum</field> -->
            <field name="report_line_id" ref="pl_total_income_line"/>
        </record>

        <!-- Expenses -->
        <record id="pl_expense_line" model="account.report.line">
            <field name="name">Expenses</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">15</field>
            <field name="code">EXPENSES</field>
        </record>

        <!-- Gross Profit -->
        <record id="pl_gross_profit_line" model="account.report.line">
            <field name="name">Gross Profit</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">15</field>
            <field name="hierarchy_level">0</field>
            <field name="code">GROSS</field>
        </record>

        <record id="gross_profit_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">aggregation</field>
            <field name="formula">TR.balance - TCOGS.balance</field>
            <field name="report_line_id" ref="pl_gross_profit_line"/>
        </record>


        <!-- Cost of Goods Sold -->
        <record id="pl_cost_of_goods_sold_line" model="account.report.line">
            <field name="name">Cost of Goods Sold</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">16</field>
            <field name="hierarchy_level">3</field>
            <field name="code">CGS</field>
        </record>

        <record id="cgs_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">aggregation</field>
            <field name="formula">OS.balance + PURCHASE.balance + DE.balance - CS.balance</field>
            <field name="report_line_id" ref="pl_cost_of_goods_sold_line"/>
        </record>

        <!-- Opening Stock -->
        <record id="pl_opening_stock_line" model="account.report.line">
            <field name="name">Opening Stock</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">16</field>
            <field name="hierarchy_level">5</field>
            <field name="code">OS</field>
        </record>

        <record id="opening_stock_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'OS')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_opening_stock_line"/>
        </record>

        <!-- Purchase -->
        <record id="pl_purchase_line" model="account.report.line">
            <field name="name">Purchase</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">17</field>
            <field name="hierarchy_level">5</field>
            <field name="code">PURCHASE</field>
        </record>

        <record id="purchase_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'PURCHASE')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_purchase_line"/>
