            <field name="code">CS</field>
        </record>

        <record id="cs_expression" model="account.report.expression">
            <field name="label">balance</field>
            <field name="engine">domain</field>
            <field name="formula">[('account_id.oman_format', '=', 'CS')]</field>
            <field name="subformula">sum</field>
            <field name="report_line_id" ref="pl_closing_stock_line"/>
        </record>
        
        <!-- Operating Expenses -->
        <record id="pl_operating_expenses_line" model="account.report.line">
            <field name="name">Operating Expenses</field>
            <field name="user_groupby">account_id</field>
            <field name="foldable">true</field>
            <field name="report_id" ref="account_report_template_pl"/>
            <field name="sequence">20</field>
            <field name="hierarchy_level">3</field>
            <field name="code">OE</field>
