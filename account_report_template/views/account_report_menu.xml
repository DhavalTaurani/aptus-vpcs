<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Balance Sheet Action -->
        <record id="action_account_report_bs_custom" model="ir.actions.client">
            <field name="name">Balance Sheet Oman Format</field>
            <field name="tag">account_report</field>
            <field name="path">balancesheet-report</field>
            <field name="context" eval="{'report_id': ref('account_report_template.account_report_template_pnl')}"/>
        </record>

        <!-- Profit & Loss Action -->
        <record id="action_account_report_pl_custom" model="ir.actions.client">
            <field name="name">Profit &amp; Loss Report Oman Format</field>
            <field name="tag">account_report</field>
            <field name="path">pnl-report</field>
            <field name="context" eval="{'report_id': ref('account_report_template.account_report_template_pl')}"/>
        </record>

        <!-- Balance Sheet Menu -->
        <menuitem id="menu_action_account_report_tmpl_bsheet"
                  name="Balance Sheet Oman Format"
                  action="action_account_report_bs_custom"
                  parent="account.menu_finance_reports"
                  sequence="100"/>

        <!-- Profit & Loss Menu -->
        <menuitem id="menu_action_account_report_tmpl_pl"
                  name="Profit &amp; Loss Report Oman Format"
                  action="action_account_report_pl_custom"
                  parent="account.menu_finance_reports"
                  sequence="101"/>
    </data>
</odoo>
