<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_form_inherit_oman" model="ir.ui.view">
        <field name="name">account.account.form.inherit.oman</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="oman_format" widget="oman_format_selection" placeholder="Select Oman Format Mapping..."/>
            </xpath>
        </field>
    </record>

    <!-- Server Action to map selected chart of accounts to Oman Format -->
    <record id="action_map_oman_format_server" model="ir.actions.server">
        <field name="name">Map Oman Format</field>
        <field name="model_id" ref="account.model_account_account"/>
        <field name="binding_model_id" ref="account.model_account_account"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.action_map_oman_format()
        </field>
    </record>
</odoo>
