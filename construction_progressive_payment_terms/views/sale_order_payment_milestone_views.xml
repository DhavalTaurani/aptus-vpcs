<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sale Order Payment Milestone Tree View -->
    <record id="view_sale_order_payment_milestone_tree" model="ir.ui.view">
        <field name="name">sale.order.payment.milestone.tree</field>
        <field name="model">sale.order.payment.milestone</field>
        <field name="arch" type="xml">
            <list string="Payment Milestones" decoration-info="state=='draft'" decoration-success="state=='ready'" decoration-warning="state=='invoiced'" decoration-muted="state=='cancelled'">
                <field name="sequence" widget="handle"/>
                <field name="milestone_name"/>
                <field name="milestone_type"/>
                <field name="percentage"/>
                <field name="amount" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
                <field name="planned_date"/>
                <field name="actual_date"/>
                <field name="state" widget="badge"/>
                <field name="task_count" optional="hide"/>
                <field name="task_progress" 
                    optional="hide"
                    widget="progressbar"/>
                <field name="combined_progress" 
                    optional="hide"
                    widget="progressbar"/>
                <field name="progress_percentage" widget="progressbar"/>
                <field name="sale_order_id"/>
                <field name="analytic_account_id" optional="hide" groups="analytic.group_analytic_accounting"/>
            </list>
        </field>
    </record>

    <!-- Sale Order Payment Milestone Form View -->
    <record id="view_sale_order_payment_milestone_form" model="ir.ui.view">
        <field name="name">sale.order.payment.milestone.form</field>
        <field name="model">sale.order.payment.milestone</field>
        <field name="arch" type="xml">
            <form string="Payment Milestone">
                <header>
                    <button name="action_set_ready" string="Set Ready" type="object" invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_invoice" string="Create Invoice" type="object" invisible="state != 'ready'" class="btn-primary"/>
                    <button name="action_approve" string="Approve" type="object" invisible="state != 'draft' or not approval_required" class="btn-success"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state in ['draft', 'paid']" class="btn-warning" confirm="Are you sure you want to reset this milestone to draft? This will handle any linked invoices."/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ['draft', 'ready']" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready,invoiced,paid"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="not invoice_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Invoice</span>
                            </div>
                        </button>
                        <button name="action_view_sub_milestones" type="object" class="oe_stat_button" icon="fa-list" invisible="not has_sub_milestones">
                            <div class="o_field_widget o_stat_info">
                                <field name="sub_milestone_ids" widget="statinfo" string="Sub-milestones"/>
                            </div>
                        </button>
                        <button name="action_view_project_tasks" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-tasks"
                                invisible="task_count == 0">
                            <field name="task_count" widget="statinfo" string="Tasks"/>
                        </button>
                        
                        <button name="action_sync_task_progress" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-refresh"
                                invisible="task_count == 0">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="task_progress" widget="percentage"/>
                                </span>
                                <span class="o_stat_text">Task Progress</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="milestone_name"/>
                            <field name="milestone_type"/>
                            <field name="sale_order_id"/>
                            <field name="payment_term_line_id"/>
                            <field name="analytic_account_id" readonly="1" groups="analytic.group_analytic_accounting"/>
                        </group>
                        <group>
                            <field name="percentage"/>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="progress_percentage" widget="progressbar"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="planned_date"/>
                            <field name="actual_date"/>
                            <field name="approval_required"/>
                            <field name="allow_sub_milestones"/>
                            <field name="has_sub_milestones"/>
                        </group>
                        <group>
                            <field name="approved_by" invisible="not approved_by"/>
                            <field name="approved_date" invisible="not approved_date"/>
                            <field name="invoice_id" invisible="not invoice_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                            <field name="combined_progress" widget="progressbar" invisible="task_count == 0"/>
                        </page>
                        <page string="Required Documents">
                            <field name="required_documents"/>
                        </page>
                        <page string="Sub-milestones" invisible="not allow_sub_milestones">
                            <field name="sub_milestone_ids">
                            <list>
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="percentage"/>
                                <field name="amount" widget="monetary"/>
                                <field name="planned_date"/>
                                <field name="state" widget="badge"/>
                                <field name="analytic_account_id" optional="hide" groups="analytic.group_analytic_accounting"/>
                                <button name="action_set_ready" string="Set Ready" type="object" 
                                    invisible="state != 'draft'" class="btn-sm btn-primary"/>
                                <button name="action_complete" string="Complete" type="object" 
                                    invisible="state != 'ready'" class="btn-sm btn-success"/>
                                <button name="action_create_invoice" string="Invoice" type="object" 
                                    invisible="state != 'completed'" class="btn-sm btn-primary"/>
                                <button name="action_reset_to_draft" string="Reset" type="object" 
                                    invisible="state in ['draft']" class="btn-sm btn-warning"/>
                            </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sale Order Payment Milestone Kanban View -->
    <record id="view_sale_order_payment_milestone_kanban" model="ir.ui.view">
        <field name="name">sale.order.payment.milestone.kanban</field>
        <field name="model">sale.order.payment.milestone</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="milestone_name"/>
                <field name="milestone_type"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="progress_percentage"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="milestone_name"/></strong>
                                        <br/>
                                        <small class="o_kanban_record_subtitle text-muted">
                                            <field name="milestone_type"/>
                                        </small>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="amount" widget="monetary"/>
                                    <div class="mt8">
                                        <field name="progress_percentage" widget="progressbar"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Sale Order Payment Sub-milestone Form View -->
    <record id="view_sale_order_payment_milestone_sub_form" model="ir.ui.view">
        <field name="name">sale.order.payment.milestone.sub.form</field>
        <field name="model">sale.order.payment.milestone.sub</field>
        <field name="arch" type="xml">
            <form string="Sub-milestone">
                <header>
                    <button name="action_set_ready" string="Set Ready" type="object" 
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_complete" string="Complete" type="object" 
                            invisible="state != 'ready'" class="btn-success"/>
                    <button name="action_create_invoice" string="Create Invoice" type="object" 
                            invisible="state != 'completed'" class="btn-primary"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" 
                            invisible="state in ['draft']" class="btn-warning"/>
                    <button name="action_cancel" string="Cancel" type="object" 
                            invisible="state not in ['draft', 'ready']" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready,completed,invoiced"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="parent_milestone_id" readonly="1"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="percentage"/>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="planned_date"/>
                            <field name="actual_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Unified Milestone Tasks Tree View -->
    <record id="view_milestone_all_tasks_tree" model="ir.ui.view">
        <field name="name">milestone.all.tasks.tree</field>
        <field name="model">sale.order.payment.milestone</field>
        <field name="arch" type="xml">
            <list string="All Milestones" decoration-info="state=='draft'" decoration-success="state=='ready'" decoration-warning="state=='invoiced'" decoration-muted="state=='cancelled'" create="false">
                <field name="milestone_name"/>
                <field name="milestone_type"/>
                <field name="percentage"/>
                <field name="amount" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
                <field name="planned_date"/>
                <field name="state" widget="badge"/>
                <field name="progress_percentage" widget="progressbar"/>
                <field name="allow_sub_milestones" invisible="1"/>
                <field name="has_sub_milestones" invisible="1"/>
                <!-- Parent milestone actions -->
                <button name="action_set_ready" string="Set Ready" type="object" 
                        invisible="state != 'draft'" class="btn-sm btn-primary"/>
                <button name="action_create_milestone_invoice" string="Invoice" type="object" 
                        invisible="state != 'ready'" class="btn-sm btn-success"/>
                <button name="action_reset_to_draft" string="Reset" type="object" 
                        invisible="state in ['draft']" class="btn-sm btn-warning"/>
                <!-- Sub-milestones section -->
                <field name="sub_milestone_ids" invisible="not has_sub_milestones">
                    <list string="Sub-milestones" decoration-info="state=='draft'" decoration-success="state=='ready'" decoration-warning="state=='completed'" create="true" delete="true">
                        <field name="name"/>
                        <field name="percentage"/>
                        <field name="amount" widget="monetary"/>
                        <field name="planned_date"/>
                        <field name="state" widget="badge"/>
                        <button name="action_set_ready" string="Set Ready" type="object" 
                                invisible="state != 'draft'" class="btn-sm btn-primary"/>
                        <button name="action_complete" string="Complete" type="object" 
                                invisible="state != 'ready'" class="btn-sm btn-success"/>
                        <button name="action_create_invoice" string="Invoice" type="object" 
                                invisible="state != 'completed'" class="btn-sm btn-primary"/>
                        <button name="action_reset_to_draft" string="Reset" type="object" 
                                invisible="state in ['draft']" class="btn-sm btn-warning"/>
                    </list>
                </field>
            </list>
        </field>
    </record>

    <!-- Action for Sale Order Payment Milestones -->
    <record id="action_sale_order_payment_milestone" model="ir.actions.act_window">
        <field name="name">Payment Milestones</field>
        <field name="res_model">sale.order.payment.milestone</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No payment milestones found!
            </p>
            <p>
                Payment milestones are automatically created when you use progressive payment terms in sale orders.
            </p>
        </field>
    </record>
</odoo>