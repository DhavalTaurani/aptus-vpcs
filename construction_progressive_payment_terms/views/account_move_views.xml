<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend Account Move Form View -->
    <record id="view_move_form_progressive_payment" model="ir.ui.view">
        <field name="name">account.move.form.progressive.payment</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add milestone button to button box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_milestones" type="object" class="oe_stat_button" icon="fa-tasks" invisible="not is_milestone_invoice">
                    <div class="o_field_widget o_stat_info">
                        <field name="milestone_count" widget="statinfo" string="Milestones"/>
                    </div>
                </button>
                <button name="action_view_source_sale_order" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="not source_sale_order_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Sale Order</span>
                    </div>
                </button>
            </xpath>

            <!-- Add milestone fields -->
            <xpath expr="//field[@name='invoice_origin']" position="after">
                <field name="is_milestone_invoice" invisible="1"/>
                <field name="source_sale_order_id" invisible="not is_milestone_invoice" readonly="1"/>
            </xpath>

            <!-- Add milestone information tab -->
            <xpath expr="//page[@name='other_info']" position="after">
                <page string="Milestone Information" invisible="not is_milestone_invoice">
                    <group>
                        <field name="milestone_ids" nolabel="1">
                            <list>
                                <field name="milestone_name"/>
                                <field name="milestone_type"/>
                                <field name="percentage"/>
                                <field name="amount" widget="monetary"/>
                                <field name="state" widget="badge"/>
                                <field name="progress_percentage" widget="progressbar"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Extend Account Move Tree View -->
    <record id="view_move_tree_progressive_payment" model="ir.ui.view">
        <field name="name">account.move.tree.progressive.payment</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="is_milestone_invoice" optional="hide"/>
                <field name="milestone_count" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Extend Account Move Line Tree View -->
    <record id="view_move_line_tree_progressive_payment" model="ir.ui.view">
        <field name="name">account.move.line.tree.progressive.payment</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="milestone_name" optional="hide"/>
                <field name="milestone_type" optional="hide"/>
                <field name="is_milestone_line" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>