            <field name="is_boq_item">true</field>
            <field name="boq_code">ELV-ACC-001</field>
            <field name="estimated_quantity">1</field>
            <field name="unit_cost">3000</field>
            <field name="cost_code_id" ref="cost_code_template_equipment"/>
        </record>
        
        <!-- MEP Construction Template -->
        <record id="template_mep" model="construction.project.template">
            <field name="name">Mechanical, Electrical &amp; Plumbing (MEP)</field>
            <field name="construction_category">mep</field>
            <field name="description">Standard template for MEP projects including HVAC, electrical, and plumbing systems</field>
            <field name="state">draft</field>
            <field name="version">1.0</field>
            <field name="template_data">{"version": "1.0", "category": "mep", "structure": {"phases": ["mechanical", "electrical", "plumbing"], "cost_categories": ["material", "labour", "equipment", "subcontractor"], "milestones": ["design_approval", "mechanical_complete", "electrical_complete", "plumbing_complete"]}, "validation_rules": {"min_cost": 5000, "max_duration": 120, "required_approvals": ["technical", "safety", "financial"]}, "backup_config": {"auto_backup": true, "retention_days": 365, "backup_frequency": "weekly"}}</field>
        </record>
        
        <!-- MEP Task Templates -->
        <record id="mep_task_mechanical" model="construction.task.template">
            <field name="name">Mechanical Systems</field>
            <field name="template_id" ref="template_mep"/>
            <field name="sequence">10</field>
