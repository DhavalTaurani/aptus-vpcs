<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template Data with proper noupdate flags for data integrity -->
    <data noupdate="1">
        
        <!-- ELV Construction Template -->
        <record id="template_elv" model="construction.project.template">
            <field name="name">Extra Low Voltage (ELV) Project</field>
            <field name="construction_category">elv</field>
            <field name="description">Standard template for Extra Low Voltage projects including CCTV, access control, fire alarm systems</field>
            <field name="state">draft</field>
            <field name="version">1.0</field>
            <field name="template_data">{"version": "1.0", "category": "elv", "structure": {"phases": ["design", "installation", "testing"], "cost_categories": ["material", "labour", "equipment"], "milestones": ["design_approval", "installation_complete", "testing_complete"]}, "validation_rules": {"min_cost": 1000, "max_duration": 90, "required_approvals": ["technical", "financial"]}, "backup_config": {"auto_backup": true, "retention_days": 365, "backup_frequency": "weekly"}}</field>
        </record>
        
        <!-- ELV Task Templates -->
        <record id="elv_task_design" model="construction.task.template">
            <field name="name">Design and Engineering</field>
            <field name="template_id" ref="template_elv"/>
            <field name="sequence">10</field>
            <field name="description">System design, drawings, and engineering calculations</field>
            <field name="is_boq_item">false</field>
        </record>
        
        <record id="elv_task_cctv" model="construction.task.template">
            <field name="name">CCTV System Installation</field>
            <field name="template_id" ref="template_elv"/>
            <field name="parent_template_id" ref="elv_task_design"/>
            <field name="sequence">20</field>
            <field name="description">CCTV cameras, DVR/NVR, and monitoring equipment</field>
            <field name="is_boq_item">true</field>
            <field name="boq_code">ELV-CCTV-001</field>
            <field name="estimated_quantity">1</field>
            <field name="unit_cost">5000</field>
            <field name="cost_code_id" ref="cost_code_template_equipment"/>
        </record>
        
        <record id="elv_task_access" model="construction.task.template">
            <field name="name">Access Control System</field>
            <field name="template_id" ref="template_elv"/>
            <field name="parent_template_id" ref="elv_task_design"/>
