<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Template Management Groups -->
        <record id="group_construction_template_user" model="res.groups">
            <field name="name">A Template User</field>
            <!-- <field name="privilege_id" ref="privilege_construction"/> -->
            <field name="implied_ids" eval="[(4, ref('group_construction_user'))]"/>
            <field name="comment">Can use approved templates to create projects</field>
        </record>

        <record id="group_construction_template_manager" model="res.groups">
            <field name="name">A Template Manager</field>
            <!-- <field name="privilege_id" ref="privilege_construction"/> -->
            <field name="implied_ids" eval="[(4, ref('group_construction_template_user')), (4, ref('group_construction_manager'))]"/>
            <field name="comment">Can create, modify, approve, and manage construction templates</field>
        </record>

        <!-- Template Access Rules -->
        <record id="construction_template_user_rule" model="ir.rule">
            <field name="name">Template User Access</field>
            <field name="model_id" ref="model_construction_project_template"/>
            <field name="domain_force">[('state', '=', 'approved')]</field>
            <field name="groups" eval="[(4, ref('group_construction_template_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="construction_template_manager_rule" model="ir.rule">
            <field name="name">Template Manager Access</field>
            <field name="model_id" ref="model_construction_project_template"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_construction_template_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Template Version Access Rules -->
        <record id="construction_template_version_user_rule" model="ir.rule">
            <field name="name">Template Version User Access</field>
            <field name="model_id" ref="model_construction_template_version"/>
            <field name="domain_force">[('state', '=', 'approved')]</field>
            <field name="groups" eval="[(4, ref('group_construction_template_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="construction_template_version_manager_rule" model="ir.rule">
            <field name="name">Template Version Manager Access</field>
            <field name="model_id" ref="model_construction_template_version"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_construction_template_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Template Analytics Access Rules -->
        <record id="construction_template_analytics_rule" model="ir.rule">
            <field name="name">Template Analytics Access</field>
            <field name="model_id" ref="model_construction_template_analytics"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_construction_template_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Template Usage Log Access Rules -->
        <record id="construction_template_usage_log_rule" model="ir.rule">
            <field name="name">Template Usage Log Access</field>
            <field name="model_id" ref="model_construction_template_usage_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_construction_template_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Note: Template Import/Export is a transient model (wizard) and doesn't need ir.rule records -->

    </data>
</odoo>