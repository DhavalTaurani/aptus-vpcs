<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Construction Management Categories -->
        <record id="module_category_construction" model="ir.module.category">
            <field name="name">Construction Management</field>
            <field name="description">Manage construction projects, BOQ, costs, and subcontractors</field>
            <field name="sequence">15</field>
        </record>

        <!-- <record id="privilege_construction" model="res.groups.privilege">
            <field name="name">Construction Management</field>
            <field name="category_id" ref="module_category_construction"/>
            <field name="description">Construction related privileges</field>
        </record> -->

        <!-- Construction Management Groups -->
        <record id="group_construction_user" model="res.groups">
            <field name="name">A Construction User</field>
            <!-- <field name="privilege_id" ref="privilege_construction"/> -->
            <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
            <field name="comment">Basic construction management access - can view and update assigned tasks</field>
        </record>

        <record id="group_construction_manager" model="res.groups">
            <field name="name">A Construction Manager</field>
            <!-- <field name="privilege_id" ref="privilege_construction"/> -->
            <field name="implied_ids" eval="[(4, ref('group_construction_user')), (4, ref('project.group_project_manager'))]"/>
            <field name="comment">Construction project management - can manage projects, BOQ, and subcontractors</field>
        </record>

        <record id="group_construction_admin" model="res.groups">
            <field name="name">A Construction Administrator</field>
            <!-- <field name="privilege_id" ref="privilege_construction"/> -->
            <field name="implied_ids" eval="[(4, ref('group_construction_manager')), (4, ref('base.group_system'))]"/>
            <field name="comment">Full construction system administration - can configure cost codes, templates, and system settings</field>
        </record>

        <record id="group_construction_finance" model="res.groups">
            <field name="name">A Construction Finance</field>
            <!-- <field name="privilege_id" ref="privilege_construction"/> -->
            <field name="implied_ids" eval="[(4, ref('group_construction_user')), (4, ref('account.group_account_user'))]"/>
            <field name="comment">Construction financial management - can manage budgets, costs, and revenue recognition</field>
        </record>

        <record id="group_construction_procurement" model="res.groups">
            <field name="name">A Construction Procurement</field>
            <!-- <field name="privilege_id" ref="privilege_construction"/> -->
            <field name="implied_ids" eval="[(4, ref('group_construction_user')), (4, ref('purchase.group_purchase_user'))]"/>
            <field name="comment">Construction procurement management - can manage purchase orders and material tracking</field>
        </record>

        <!-- Record Rules for Project-based Access -->
        <record id="construction_project_rule" model="ir.rule">
            <field name="name">Construction Project Access</field>
            <field name="model_id" ref="model_project_project"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_construction_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="construction_project_manager_rule" model="ir.rule">
            <field name="name">Construction Project Manager Access</field>
            <field name="model_id" ref="model_project_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_construction_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Task Access Rules -->
        <record id="construction_task_rule" model="ir.rule">
            <field name="name">Construction Task Access</field>
            <field name="model_id" ref="model_project_task"/>
            <field name="domain_force">['|', ('user_ids', 'in', [user.id]), ('project_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_construction_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Financial Data Access Rules -->
        <record id="construction_financial_rule" model="ir.rule">
            <field name="name">Construction Financial Data Access</field>
            <field name="model_id" ref="model_account_move_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_construction_finance'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>