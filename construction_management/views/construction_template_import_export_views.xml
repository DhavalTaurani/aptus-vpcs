<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Template Import/Export Views -->
    <record id="view_construction_template_import_export_form" model="ir.ui.view">
        <field name="name">construction.template.import.export.form</field>
        <field name="model">construction.template.import.export</field>
        <field name="arch" type="xml">
            <form string="Template Import/Export">
                <header>
                    <button name="action_export_templates" string="Export Templates" type="object" 
                            class="btn-primary" invisible="operation != 'export'"/>
                    <button name="action_import_templates" string="Import Templates" type="object" 
                            class="btn-primary" invisible="operation != 'import'"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            Template <field name="operation" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <field name="operation" widget="radio" options="{'horizontal': true}"/>
                    </group>
                    
                    <!-- Export Section -->
                    <group invisible="operation != 'export'" string="Export Configuration">
                        <group name="export_templates" string="Templates to Export">
                            <field name="template_ids" widget="many2many_tags" nolabel="1"/>
                        </group>
                        <group name="export_options" string="Export Options">
                            <field name="include_versions"/>
                            <field name="include_analytics"/>
                        </group>
                    </group>
                    
                    <!-- Import Section -->
                    <group invisible="operation != 'import'" string="Import Configuration">
                        <group name="import_file" string="Import File">
                            <field name="import_file" filename="import_filename"/>
                            <field name="import_filename" invisible="1"/>
                        </group>
                        <group name="import_options" string="Import Options">
                            <field name="overwrite_existing"/>
                            <field name="create_backup"/>
                        </group>
                    </group>
                    
                    <!-- Export Result -->
                    <group invisible="export_file == False" string="Export Result">
                        <field name="export_file" filename="export_filename" readonly="1"/>
                        <field name="export_filename" invisible="1"/>
                    </group>
                    
                    <!-- Operation Log -->
                    <group invisible="operation_log == False" string="Operation Log">
                        <field name="operation_log" widget="text" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Action for Template Import/Export -->
    <record id="action_construction_template_import_export" model="ir.actions.act_window">
        <field name="name">Import/Export Templates</field>
        <field name="res_model">construction.template.import.export</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>
    
    <!-- Server Action for Export Templates -->
    <record id="action_server_export_templates" model="ir.actions.server">
        <field name="name">Export Selected Templates</field>
        <field name="model_id" ref="model_construction_project_template"/>
        <field name="binding_model_id" ref="model_construction_project_template"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
# Create export wizard with selected templates
wizard = env['construction.template.import.export'].create({
    'operation': 'export',
    'template_ids': [(6, 0, records.ids)],
})

action = {
    'type': 'ir.actions.act_window',
    'res_model': 'construction.template.import.export',
    'res_id': wizard.id,
    'view_mode': 'form',
    'target': 'new',
    'name': 'Export Templates',
}
        </field>
    </record>
    
    <!-- Menu Items for Template Management -->
    <menuitem id="menu_construction_template_management" 
            name="Template Management" 
            parent="construction_management.menu_construction_configuration"
            sequence="20"/>
    
    <menuitem id="menu_construction_template_analytics" 
            name="Template Analytics" 
            parent="menu_construction_template_management"
            action="action_construction_template_analytics"
            sequence="10"/>
    
    <menuitem id="menu_construction_template_versions" 
            name="Template Versions" 
            parent="menu_construction_template_management"
            action="action_construction_template_version"
            sequence="20"/>
    
    <menuitem id="menu_construction_template_usage_log" 
            name="Usage Log" 
            parent="menu_construction_template_management"
            action="action_construction_template_usage_log"
            sequence="30"/>
    
    <menuitem id="menu_construction_template_import_export" 
            name="Import/Export" 
            parent="menu_construction_template_management"
            action="action_construction_template_import_export"
            sequence="40"/>
    
</odoo>