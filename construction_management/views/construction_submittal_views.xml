<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Submittal Search View -->
        <record id="view_construction_submittal_search" model="ir.ui.view">
            <field name="name">construction.submittal.search</field>
            <field name="model">construction.submittal</field>
            <field name="arch" type="xml">
                <search string="Search Submittals">
                    <field name="name" string="Submittal Number"/>
                    <field name="project_id"/>
                    <field name="task_id"/>
                    <field name="submittal_type"/>
                    <field name="state"/>
                    <separator/>
                    <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Submitted" name="state_submitted" domain="[('state', '=', 'submitted')]"/>
                    <filter string="Under Review" name="state_under_review" domain="[('state', '=', 'under_review')]"/>
                    <filter string="Approved" name="state_approved" domain="[('state', '=', 'approved')]"/>
                    <filter string="Rejected" name="state_rejected" domain="[('state', '=', 'rejected')]"/>
                    <filter string="Resubmit Required" name="state_resubmit" domain="[('state', '=', 'resubmit')]"/>
                    <separator/>
                    <filter string="Project" name="group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Submittal Type" name="group_by_submittal_type" context="{'group_by': 'submittal_type'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                </search>
            </field>
        </record>

        <!-- Submittal Tree View -->
        <record id="view_construction_submittal_tree" model="ir.ui.view">
            <field name="name">construction.submittal.tree</field>
            <field name="model">construction.submittal</field>
            <field name="arch" type="xml">
                <list string="Submittals">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="task_id"/>
                    <field name="submittal_type"/>
                    <field name="state"/>
                    <field name="submission_date"/>
                    <field name="review_deadline"/>
                    <field name="approval_date"/>
                </list>
            </field>
        </record>

        <!-- Submittal Form View -->
        <record id="view_construction_submittal_form" model="ir.ui.view">
            <field name="name">construction.submittal.form</field>
            <field name="model">construction.submittal</field>
            <field name="arch" type="xml">
                <form string="Submittal">
                    <header>
                        <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state not in ['draft', 'resubmit']"/>
                        <button name="action_send_for_review" string="Send for Review" type="object" class="oe_highlight" invisible="state not in ['submitted']"/>
                        <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state not in ['under_review']"/>
                        <button name="action_reject" string="Reject" type="object" invisible="state not in ['under_review']"/>
                        <button name="action_resubmit" string="Resubmit" type="object" invisible="state not in ['rejected']"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted,under_review,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Submittal Number..."/>
                            </h1>
                        </div>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" icon="fa-paperclip" type="object"
                                    name="action_view_attachments">
                                <field string="Attachments" name="attachment_count" widget="statinfo"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="project_id"/>
                                <field name="task_id"/>
                                <field name="submittal_type"/>
                            </group>
                            <group>
                                <field name="submission_date"/>
                                <field name="review_deadline"/>
                                <field name="approval_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="description"/>
                            </page>
                            <page string="Attachments">
                                <field name="attachment_ids" widget="many2many_binary"/>
                            </page>
                            <page string="Review">
                                <group>
                                    <field name="reviewer_id"/>
                                    <field name="review_comments"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Submittal Action -->
        <record id="action_construction_submittal" model="ir.actions.act_window">
            <field name="name">Submittals</field>
            <field name="res_model">construction.submittal</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_construction_submittal_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create and manage project submittals.
                </p>
            </field>
        </record>

        <!-- <menuitem id="menu_construction_submittals" 
                name="Submittals" 
                parent="menu_construction_document_management" 
                action="action_construction_submittal" 
                sequence="20"/> -->

    </data>
</odoo>
