<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Construction Project Template Views -->
        <record id="view_construction_project_template_tree" model="ir.ui.view">
            <field name="name">construction.project.template.tree</field>
            <field name="model">construction.project.template</field>
            <field name="arch" type="xml">
                <list string="Construction Project Templates" decoration-success="state=='approved'" decoration-info="state=='draft'">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="construction_category"/>
                    <field name="version"/>
                    <field name="state" widget="badge" decoration-success="state=='approved'" decoration-info="state=='draft'"/>
                    <field name="usage_count"/>
                    <field name="last_used_date"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </list>
            </field>
        </record>
        
        <record id="view_construction_project_template_form" model="ir.ui.view">
            <field name="name">construction.project.template.form</field>
            <field name="model">construction.project.template</field>
            <field name="arch" type="xml">
                <form string="Construction Project Template">
                    <header>
                        <button name="action_submit_for_review" string="Submit for Review" type="object" 
                                class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_approve_template" string="Approve" type="object" 
                                class="btn-success" invisible="state != 'review'"
                                groups="construction_management.group_construction_template_manager"/>
                        <button name="action_reject_template" string="Reject" type="object" 
                                class="btn-warning" invisible="state != 'review'"
                                groups="construction_management.group_construction_template_manager"/>
                        <button name="action_archive_template" string="Archive" type="object" 
                                class="btn-secondary" invisible="state in ['archived', 'review']"/>
                        <button name="create_version_backup" string="Create Backup" type="object" 
                                class="btn-secondary" invisible="state == 'draft'"/>
                        <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                                class="btn-primary" invisible="state != 'approved'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,review,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_projects"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-tasks">
                                <field name="usage_count" widget="statinfo" string="Projects"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1><field name="name" placeholder="Template Name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="construction_category"/>
                                <field name="version"/>
                                <field name="sequence"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="project_template_id" domain="[('active', '=', True)]"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="last_used_date" readonly="1"/>
                            </group>
                        </group>
                        <group string="Approval">
                            <group>
                                <field name="approved_by" readonly="1"/>
                                <field name="approved_date" readonly="1"/>
                            </group>
                            <group>
                                <field name="review_notes"/>
                            </group>
                        </group>
                        <field name="description" placeholder="Template description..."/>
                        <notebook>
                            <page string="Task Templates" name="tasks">
                                <field name="task_template_ids">
                                <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="hierarchy_level"/>
                                        <field name="parent_template_id" domain="[('template_id', '=', parent.id)]"/>
                                        <field name="initial_stage"/>
                                        <field name="is_boq_item"/>
                                        <field name="boq_code" invisible="is_boq_item == False"/>
                                        <field name="estimated_quantity" invisible="is_boq_item == False"/>
                                        <field name="unit_cost" invisible="is_boq_item == False"/>
                                        <field name="cost_code_id" invisible="is_boq_item == False"/>
                                        <field name="currency_id" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="BOQ Templates" name="boq">
                                <field name="boq_template_ids">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="code"/>
                                        <field name="name"/>
                                        <field name="task_template_id" domain="[('template_id', '=', parent.id)]"/>
                                        <field name="quantity"/>
                                        <field name="unit_of_measure_id"/>
                                        <field name="unit_cost"/>
                                        <field name="total_cost"/>
                                        <field name="cost_code_id"/>
                                        <field name="currency_id" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Cost Estimation" name="costs">
                                <field name="cost_estimation_ids">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="cost_category"/>
                                        <field name="estimated_cost"/>
                                        <field name="contingency_percentage"/>
                                        <field name="total_cost"/>
                                        <field name="historical_average"/>
                                        <field name="variance_percentage"/>
                                        <field name="currency_id" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <!-- <page string="Milestones" name="milestones">
                                <field name="milestone_template_ids">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="milestone_type"/>
                                        <field name="days_from_start"/>
                                        <field name="is_payment_milestone"/>
                                        <field name="payment_percentage" invisible="is_payment_milestone == False"/>
                                        <field name="depends_on_task"/>
                                        <field name="task_template_id" invisible="depends_on_task == False" domain="[('template_id', '=', parent.id)]"/>
                                    </list>
                                </field>
                            </page> -->
                            <page string="Template Data" name="data">
                                <group>
                                    <field name="template_data" widget="text" placeholder="Enter JSON template configuration data here..."/>
                                </group>
                                <div class="alert alert-info" role="alert">
                                    <strong>Template Data Format:</strong> Use JSON format to store template configuration data.
                                    <br/>Example: {"version": "1.0", "settings": {"auto_generate_tasks": true}}
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        
        <!-- Construction Task Template Views -->
        <record id="view_construction_task_template_tree" model="ir.ui.view">
            <field name="name">construction.task.template.tree</field>
            <field name="model">construction.task.template</field>
            <field name="arch" type="xml">
            <list string="Construction Task Templates">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="parent_template_id"/>
                    <field name="is_boq_item"/>
                    <field name="boq_code"/>
                    <field name="estimated_quantity"/>
                    <field name="unit_cost"/>
                    <field name="cost_code_id"/>
                </list>
            </field>
        </record>
        
        <!-- Construction BOQ Template Views -->
        <record id="view_construction_boq_template_tree" model="ir.ui.view">
            <field name="name">construction.boq.template.tree</field>
            <field name="model">construction.boq.template</field>
            <field name="arch" type="xml">
            <list string="Construction BOQ Templates">
                    <field name="sequence" widget="handle"/>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="quantity"/>
                    <field name="unit_of_measure_id"/>
                    <field name="unit_cost"/>
                    <field name="total_cost"/>
                    <field name="cost_code_id"/>
                </list>
            </field>
        </record>
        
        <!-- Construction Cost Code Views -->
        <record id="view_construction_cost_code_tree" model="ir.ui.view">
            <field name="name">construction.cost.code.tree</field>
            <field name="model">construction.cost.code</field>
            <field name="arch" type="xml">
            <list string="Construction Cost Codes">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="cost_type"/>
                    <field name="parent_id"/>
                    <field name="standard_cost"/>
                    <field name="standard_price"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </list>
            </field>
        </record>
        
        <record id="view_construction_cost_code_form" model="ir.ui.view">
            <field name="name">construction.cost.code.form</field>
            <field name="model">construction.cost.code</field>
            <field name="arch" type="xml">
                <form string="Construction Cost Code">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1><field name="name" placeholder="Cost Code Name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="code"/>
                                <field name="cost_type"/>
                                <field name="parent_id"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="default_uom_id"/>
                                <field name="standard_cost"/>
                                <field name="standard_price"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </group>
                        <group string="Product Integration">
                            <group>
                                <field name="product_template_id"/>
                                <field name="product_category_id"/>
                            </group>
                        </group>
                        <field name="description" placeholder="Cost code description..."/>
                        <notebook>
                            <page string="Child Cost Codes" name="children" invisible="child_ids == False">
                                <field name="child_ids">
                                    <list>
                                        <field name="code"/>
                                        <field name="name"/>
                                        <field name="cost_type"/>
                                        <field name="standard_cost"/>
                                        <field name="standard_price"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        
        <!-- Menu Items -->
        <record id="action_construction_project_template" model="ir.actions.act_window">
            <field name="name">Construction Templates</field>
            <field name="res_model">construction.project.template</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first construction project template!
                </p>
                <p>
                    Construction templates help you standardize project setup with predefined BOQ items, 
                    cost codes, and task structures for different types of construction projects.
                </p>
            </field>
        </record>
        
        <record id="action_construction_cost_code" model="ir.actions.act_window">
            <field name="name">Cost Codes</field>
            <field name="res_model">construction.cost.code</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first construction cost code!
                </p>
                <p>
                    Cost codes help you categorize and track construction costs consistently 
                    across all your projects.
                </p>
            </field>
        </record>
        
        <!-- Add to Construction menu -->
        <menuitem id="menu_construction_templates" 
                name="Templates" 
                parent="construction_management.menu_construction_configuration" 
                sequence="15"/>
        
        <menuitem id="menu_construction_project_templates" 
                name="Project Templates" 
                parent="menu_construction_templates" 
                action="action_construction_project_template" 
                sequence="10"/>
        
        <menuitem id="menu_construction_cost_codes" 
                name="Cost Codes" 
                parent="menu_construction_templates" 
                action="action_construction_cost_code" 
                sequence="20"/>
        
    </data>
</odoo>