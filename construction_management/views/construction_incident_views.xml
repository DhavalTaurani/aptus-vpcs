<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Incident Tree View -->
    <record id="view_construction_incident_tree" model="ir.ui.view">
        <field name="name">construction.incident.tree</field>
        <field name="model">construction.incident</field>
        <field name="arch" type="xml">
            <list string="Safety Incidents" decoration-danger="severity=='critical'" decoration-warning="severity=='major'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="incident_date"/>
                <field name="incident_type"/>
                <field name="severity"/>
                <field name="state"/>
                <field name="reported_by_id"/>
            </list>
        </field>
    </record>

    <!-- Incident Form View -->
    <record id="view_construction_incident_form" model="ir.ui.view">
        <field name="name">construction.incident.form</field>
        <field name="model">construction.incident</field>
        <field name="arch" type="xml">
            <form string="Safety Incident">
                <header>
                    <button name="action_start_investigation" string="Start Investigation" type="object" 
                            invisible="state != 'reported'" class="btn-primary"/>
                    <button name="action_resolve_incident" string="Resolve" type="object" 
                            invisible="state != 'under_investigation'" class="btn-primary"/>
                    <button name="action_close_incident" string="Close Incident" type="object" 
                            invisible="state != 'resolved'" class="btn-success"/>
                    <button name="action_reopen_incident" string="Reopen" type="object" 
                            invisible="state != 'closed'" groups="construction_management.group_construction_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="reported,under_investigation,resolved,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" required="1"/>
                            <field name="incident_date" required="1"/>
                            <field name="incident_type" required="1"/>
                            <field name="severity" required="1"/>
                        </group>
                        <group>
                            <field name="location"/>
                            <field name="reported_by_id" required="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Incident Details">
                            <group>
                                <field name="description" nolabel="1" placeholder="Describe the incident in detail..."/>
                            </group>
                        </page>

                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Incident Kanban View -->
    <record id="view_construction_incident_kanban" model="ir.ui.view">
        <field name="name">construction.incident.kanban</field>
        <field name="model">construction.incident</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="project_id"/>
                <field name="incident_date"/>
                <field name="incident_type"/>
                <field name="severity"/>
                <field name="state"/>
                <field name="reported_by_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="project_id"/>
                                    <br/>
                                    <field name="incident_type"/>
                                    <br/>
                                    <span class="badge" t-att-class="record.severity.raw_value === 'critical' ? 'badge-danger' : record.severity.raw_value === 'major' ? 'badge-warning' : 'badge-info'">
                                        <field name="severity"/>
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="incident_date"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <img t-att-src="kanban_image('res.users', 'avatar_128', record.reported_by_id.raw_value)" 
                                        t-att-title="record.reported_by_id.value" t-att-alt="record.reported_by_id.value" 
                                        class="oe_kanban_avatar"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Incident Action -->
    <record id="action_construction_incident" model="ir.actions.act_window">
        <field name="name">Safety Incidents</field>
        <field name="res_model">construction.incident</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No safety incidents reported yet!
            </p>
            <p>
                Safety incidents should be reported immediately to ensure proper investigation and prevention measures.
            </p>
        </field>
    </record>

    <!-- Incident Types Configuration Menu -->
    <!-- <menuitem id="menu_construction_config_incident_types" 
            name="Incident Types" 
            parent="construction_management.menu_construction_config_quality" 
            action="action_construction_incident" 
            sequence="20"/> -->

</odoo>