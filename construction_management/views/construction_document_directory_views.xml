<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Document Directory Search View -->
        <record id="view_construction_document_directory_search" model="ir.ui.view">
            <field name="name">construction.document.directory.search</field>
            <field name="model">construction.document.directory</field>
            <field name="arch" type="xml">
                <search string="Search Document Directories">
                    <field name="name"/>
                    <!-- <field name="project_id"/> -->
                    <field name="document_type"/>
                    <separator/>
                    <!-- <filter string="Project" name="group_by_project" context="{'group_by': 'project_id'}"/> -->
                    <filter string="Document Type" name="group_by_document_type" context="{'group_by': 'document_type'}"/>
                </search>
            </field>
        </record>

        <!-- Document Directory Tree View -->
        <record id="view_construction_document_directory_tree" model="ir.ui.view">
            <field name="name">construction.document.directory.tree</field>
            <field name="model">construction.document.directory</field>
            <field name="arch" type="xml">
                <list string="Document Directories">
                    <field name="name"/>
                    <!-- <field name="project_id"/> -->
                    <field name="document_type"/>
                    <field name="document_count"/>
                </list>
            </field>
        </record>

        <!-- Document Directory Form View -->
        <record id="view_construction_document_directory_form" model="ir.ui.view">
            <field name="name">construction.document.directory.form</field>
            <field name="model">construction.document.directory</field>
            <field name="arch" type="xml">
                <form string="Document Directory">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Directory Name..."/>
                            </h1>
                        </div>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" icon="fa-file-text-o" type="object"
                                    name="action_view_documents">
                                <field string="Documents" name="document_count" widget="statinfo"/>
                            </button>
                            <button class="oe_stat_button" icon="fa-folder-open-o" type="object"
                                    name="action_view_subdirectories">
                                <field string="Subdirectories" name="subdirectory_count" widget="statinfo"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <!-- <field name="project_id"/> -->
                                <field name="parent_id"/>
                            </group>
                            <group>
                                <field name="document_type"/>
                                <field name="document_count"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Document Directory Action -->
        <record id="action_construction_document_directory" model="ir.actions.act_window">
            <field name="name">Document Directories</field>
            <field name="res_model">construction.document.directory</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_construction_document_directory_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create and manage your project document directories.
                </p>
            </field>
        </record>

        <!-- <menuitem id="menu_construction_document_directories" 
                name="Document Directories" 
                parent="menu_construction_document_management" 
                action="action_construction_document_directory" 
                sequence="10"/> -->

        <!-- Document Types Configuration Menu -->
        <!-- <menuitem id="menu_construction_config_document_types" 
                name="Document Types" 
                parent="construction_management.menu_construction_config_document" 
                action="action_construction_document_directory" 
                sequence="10"/> -->

    </data>
</odoo>
