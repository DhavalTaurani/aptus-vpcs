<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Quality Inspection Tree View -->
    <record id="view_construction_quality_inspection_tree" model="ir.ui.view">
        <field name="name">construction.quality.inspection.tree</field>
        <field name="model">construction.quality.inspection</field>
        <field name="arch" type="xml">
            <list string="Quality Inspections" decoration-success="state=='passed'" decoration-danger="state=='failed'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="inspection_type"/>
                <field name="inspection_date"/>
                <field name="inspector_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Quality Inspection Form View -->
    <record id="view_construction_quality_inspection_form" model="ir.ui.view">
        <field name="name">construction.quality.inspection.form</field>
        <field name="model">construction.quality.inspection</field>
        <field name="arch" type="xml">
            <form string="Quality Inspection">
                <header>
                    <button name="action_start_inspection" string="Start Inspection" type="object" 
                            invisible="state != 'scheduled'" class="btn-primary"/>
                    <button name="action_pass_inspection" string="Pass" type="object" 
                            invisible="state != 'in_progress'" class="btn-success"/>
                    <button name="action_fail_inspection" string="Fail" type="object" 
                            invisible="state != 'in_progress'" class="btn-danger"/>
                    <button name="action_reset_to_scheduled" string="Reset to Scheduled" type="object" 
                            invisible="state not in ['passed', 'failed']" groups="construction_management.group_construction_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="scheduled,in_progress,passed,failed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" required="1"/>
                            <field name="inspection_type" required="1"/>
                            <field name="inspection_date" required="1"/>
                            <field name="inspector_id" required="1"/>
                        </group>
                        <group>
                            <field name="task_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Inspection Details">
                            <group>
                                <field name="notes" nolabel="1" placeholder="Inspection notes..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Quality Inspection Kanban View -->
    <record id="view_construction_quality_inspection_kanban" model="ir.ui.view">
        <field name="name">construction.quality.inspection.kanban</field>
        <field name="model">construction.quality.inspection</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="project_id"/>
                <field name="inspection_type"/>
                <field name="inspection_date"/>
                <field name="inspector_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="project_id"/>
                                    <br/>
                                    <field name="inspection_type"/>
                                    <br/>
                                    <field name="inspection_date"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="state"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <img t-att-src="kanban_image('res.partner', 'avatar_128', record.inspector_id.raw_value)" 
                                        t-att-title="record.inspector_id.value" t-att-alt="record.inspector_id.value" 
                                        class="oe_kanban_avatar"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Quality Inspection Action -->
    <record id="action_construction_quality_inspection" model="ir.actions.act_window">
        <field name="name">Quality Inspections</field>
        <field name="res_model">construction.quality.inspection</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first quality inspection!
            </p>
            <p>
                Quality inspections help ensure construction work meets required standards.
            </p>
        </field>
    </record>

    <!-- Quality Inspections Configuration Menu -->
