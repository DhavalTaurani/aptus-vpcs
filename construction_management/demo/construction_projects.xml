            <field name="revised_quantity">52000.0</field>
            <field name="unit_cost">0.50</field>
            <field name="unit_of_measure_id" ref="uom.product_uom_unit"/>
            <field name="physical_progress">35.0</field>
            <field name="boq_state">approved</field>
            <field name="boq_description">Clay brick masonry for residential units</field>
        </record>

        <!-- ========================================== -->
        <!-- BOQ TASKS FOR GREEN VALLEY PROJECT -->
        <!-- ========================================== -->
        
