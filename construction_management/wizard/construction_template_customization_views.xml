<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Construction Template Customization Wizard Form -->
    <record id="view_construction_template_customization_wizard_form" model="ir.ui.view">
        <field name="name">construction.template.customization.wizard.form</field>
        <field name="model">construction.template.customization.wizard</field>
        <field name="arch" type="xml">
            <form string="Customize Construction Template">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="project_name" placeholder="Project Name..." required="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group name="template_selection">
                            <field name="template_id" options="{'no_create': True}"/>
                            <field name="partner_id"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group name="project_details">
                            <field name="contract_value"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    
                    <field name="project_description" placeholder="Project description..."/>
                    
                    <notebook>
                        <page string="Customization Options" name="options">
                            <group>
                                <group name="customization_flags">
                                    <field name="customize_tasks"/>
                                    <field name="customize_boq"/>
                                    <field name="customize_milestones"/>
                                    <field name="customize_resources"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Tasks" name="tasks" invisible="customize_tasks == False">
                            <field name="task_customization_ids">
                                <list editable="bottom">
                                    <field name="include_in_project"/>
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="estimated_quantity"/>
                                    <field name="unit_cost"/>
                                    <field name="total_cost" sum="Total"/>
                                    <field name="task_template_id" invisible="1"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="BOQ Items" name="boq" invisible="customize_boq == False">
                            <field name="boq_customization_ids">
                                <list editable="bottom">
                                    <field name="include_in_project"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="quantity"/>
                                    <field name="unit_cost"/>
                                    <field name="total_cost" sum="Total"/>
                                    <field name="boq_template_id" invisible="1"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Milestones" name="milestones" invisible="customize_milestones == False">
                            <field name="milestone_customization_ids">
                                <list editable="bottom">
                                    <field name="include_in_project"/>
                                    <field name="name"/>
                                    <field name="days_from_start"/>
                                    <field name="scheduled_date"/>
                                    <field name="payment_percentage"/>
                                    <field name="milestone_template_id" invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                
                <footer>
                    <button name="action_create_project" string="Create Project" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- Action for Template Customization Wizard -->
    <record id="action_construction_template_customization_wizard" model="ir.actions.act_window">
        <field name="name">Customize Construction Template</field>
        <field name="res_model">construction.template.customization.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_construction_template_customization_wizard_form"/>
    </record>
    
</odoo>