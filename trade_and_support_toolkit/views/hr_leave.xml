<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_leave_form_inherited_custom" model="ir.ui.view">
            <field name="name">hr.leave.form.inherit.custom</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='holiday_status_id']" position="after">
                    <field name="leave_type_category" readonly="state not in ('confirm', 'refuse')"/>
                </xpath>
            </field>
        </record>

        <record id="view_hr_leave_form_dashboard_inherited_custom" model="ir.ui.view">
            <field name="name">hr.leave.form.dashboard.inherit.custom</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_dashboard"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='holiday_status_id']" position="before">
                    <field name="leave_type_category" required="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
