<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Paperformat Definition -->
    <record id="paperformat_journal_voucher" model="report.paperformat">
        <field name="name">Journal Voucher</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">30</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action -->
    <record id="action_journal_voucher" model="ir.actions.report">
        <field name="name">Journal Voucher</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">aptus_macrofix_customizations.report_journal_voucher</field>
        <field name="report_file">aptus_macrofix_customizations.report_journal_voucher</field>
        <field name="print_report_name">(object.state in ('draft', 'sent') and 'Journal Voucher - %s' % (object.name)) or 'Order - %s' % (object.name)</field>
        <field name="binding_type">report</field>
        <field name="binding_model_id" search="[('model','=','account.move')]"/>
        <field name="paperformat_id" ref="aptus_macrofix_customizations.paperformat_journal_voucher"/>
    </record>

    <!-- Main Template -->
    <template id="report_journal_voucher">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="o">
                    <t t-set="company" t-value="o.company_id.sudo()"/>
                    <t t-call="aptus_macrofix_customizations.report_journal_voucher_main" t-lang="o.partner_id.lang"/>
                </t>
            </t>
        </t>
    </template>

    <!-- Body Template -->
    <template id="report_journal_voucher_main">
        <!-- Header -->
        <!-- <header>-->
<!--           <t t-set="currency" t-value="o.invoice_line_ids.purchase_line_id.order_id.currency_id"/>-->
            <div style="border-top: 1px solid; border-right: 1px solid; border-left: 1px solid; padding: 8px">
                <div class="row" style="padding-bottom: 16px">
                    <div class="col-4">
                        <img t-attf-src="data:image/*;base64,{{company.logo}}" t-att-alt="company.name"
                             style="height: 80px; width:250px;"/>
                    </div>

                    <div class="col-4" style="padding-top: 24px; padding-left: 65px;">
                        <h4><u>Journal Voucher</u></h4>
                    </div>

                    <div class="col-4" style="text-align: right">
                        <t t-if="company.parent_id">
                            <strong><t t-esc="company.parent_id.name"/></strong>
                        </t>
                        <t t-else="">
                            <strong><t t-esc="company.name"/></strong>
                        </t>
                        <br/>
                        <t t-esc="company.street"/>,
                        <br/>
                        <t t-esc="company.street2"/>,
                        <br/>
                        <span>Telephone: <t t-esc="company.phone"/> </span>
                        <br/>
                        <span>Email: <t t-esc="company.email"/> </span>
                    </div>
                </div>
                <div class="row" style="padding: 8px">
                    <div class="col-6">
                        <span>Voucher No: <t t-esc="o.name"/> </span>
                    </div>
                    <div class="col-6">
                        <span>Date: <t t-esc="o.date.strftime('%d-%m-%Y')"/> </span>
                    </div>
                </div>
            </div>
<!--        </header>-->

        <!-- Body -->
        <div class="main" style="border-bottom: 1px solid; border-right: 1px solid; border-left: 1px solid; padding: 8px">

            <div class="page">
                <hr style="color: #000000; height: 2px; width: 100%;"/>

                <div class="row" style="margin-top: -18px;">
                    <table class="table" style="width:100%; border-collapse: collapse;">
                        <thead style="padding-top:16px">
                            <tr style="background-color: rgb(211, 227, 253); font-size:14px;">
                                <th>Account</th>
                                <th>DEBIT <t t-esc="o.currency_id.symbol"/></th>
                                <th>CREDIT <t t-esc="o.currency_id.symbol"/></th>
                                <th>Customer</th>
                                <th>Analytic Account</th>
                                <th>Inst. Type</th>
                                <th>Inst. No</th>
                                <th>Narration</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="total_debit" t-value="0.000"/>
                            <t t-set="total_credit" t-value="0.000"/>

                            <t t-foreach="o.line_ids" t-as="line">
                                <t t-set="total_debit" t-value="total_debit + (line.debit or 0.000)"/>
                                <t t-set="total_credit" t-value="total_credit + (line.credit or 0.000)"/>

                                <tr style="font-size:13px;">
                                    <td style="text-align: center">
                                        <t t-if="line.account_id">
                                            <span t-esc="line.account_id.name"/>
                                        </t>
                                    </td>
                                    <td style="text-align: center">
                                        <t t-if="line.debit">
                                            <span t-esc="'%.3f' % (line.debit or 0.0)"/>
                                        </t>
                                    </td>
                                    <td style="text-align: center">
                                        <t t-if="line.credit">
                                            <span t-esc="'%.3f' % (line.credit or 0.0)"/>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-if="line.partner_id">
                                            <span t-esc="line.partner_id.name"/>
                                        </t>
                                    </td>

                                    <td>
                                        <t t-if="line.analytic_distribution">
                                            <t t-set="analytic_ids" t-value="[int(k) for k in line.analytic_distribution.keys()]"/>
                                            <t t-set="accounts" t-value="env['account.analytic.account'].browse(analytic_ids)"/>
                                            <t t-set="total" t-value="len(accounts)"/>
                                            <t t-set="index" t-value="0"/>
                                            <t t-foreach="accounts" t-as="acc">
                                                <t t-set="index" t-value="index + 1"/>
                                                <t t-esc="acc.name"/>
                                                <t t-if="index != total">, </t>
                                            </t>
                                        </t>
                                    </td>
                                    <td><span t-field="line.inst_type"/></td>
                                    <td><span t-field="line.inst_no"/></td>
                                    <td><span t-field="line.name"/></td>
                                </tr>
                            </t>

                            <tr style="font-size:13px; font-weight: bold; border: 1px solid #ffffff; text-align: center">
                                <td></td>
                                <td><t t-esc="'%.3f' % total_debit"/></td>
                                <td><t t-esc="'%.3f' % total_credit"/></td>
                                <td colspan="4"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="row">
                    <div class="col-12" style="margin-bottom: -4px;font-size: 16px;">
                        <strong>Total in Words:</strong>
                         <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                    </div>
                </div>

                <t t-if="o.narration">
                    <div class="row">
                        <div class="col-12" style="font-size: 12px;">
                            <hr style="color: #000000; height: 2px; width: 100%; margin-top:0px; margin-bottom:10px;"/>
                            <b>Internal Notes :</b> <br/>
                            <t t-esc="o.narration"/>
                        </div>
                    </div>
                </t>

                <!-- Signature Section -->
                <hr style="color: #000000; height: 2px; width: 100%;margin-top:10px;margin-bottom:0px;"/>

                <div class="row" style="page-break-inside: avoid !important; width: 100%; display: flex; padding: 10px; box-sizing: border-box;">
                    <!-- Empty Section 1 -->
                   <div style="width: 30% ;text-align: center">
                        <t t-set="created_user" t-value="o.sudo().create_uid"/>

                        <t t-if="created_user.sudo().sign_signature">
                            <img t-att-src="'data:image/png;base64,%s' % created_user.sudo().sign_signature.decode('utf-8')" style="max-height: 50px; max-width: 100%;"/>
                        </t>
                        <div>
                            <span t-esc="created_user.signature"/>
                        </div>
<!--                        <div>-->
<!--                            <span t-esc="created_user.employee_id.department_id.name"/>-->
<!--                        </div>-->
                        <strong>Prepared by</strong>
                   </div>

                   <!-- Empty Section 2 -->
                   <div style="width: 30%; padding-top: 90px; text-align: center">
                   </div>

                    <!-- Stamp Section -->
                    <div style="width: 10%;">
                        <img t-att-src="'data:image/png;base64,%s' % o.company_id.aptus_stamp.decode('utf-8')"
                             style="max-height:120px;"/>
                    </div>

                    <div style="width: 30%; text-align: center;">
                        <t t-if="company.parent_id">
                            <strong>For <t t-esc="company.parent_id.name"/></strong>
                        </t>
                        <t t-else="">
                            <strong>For <t t-esc="company.name"/></strong>
                        </t>
                        <br/><br/><br/><br/><br/>
                        <b>Authorised Signatory</b>
                    </div>
                </div>
            </div>
        </div>

         <!--Footer-->
        <footer>
            <div class="footer" style="margin-top: 20px; font-size:10px; text-align:center; border-top:1px solid black; padding-top:5px;">
                <div>
                    <span>Email: <t t-esc="company.email"/> | Website: <t t-esc="company.website"/></span>
                </div>
                <div>
                    <strong>Page <span class="page"/> of <span class="topage"/></strong>
                </div>
            </div>
        </footer>
    </template>

</odoo>