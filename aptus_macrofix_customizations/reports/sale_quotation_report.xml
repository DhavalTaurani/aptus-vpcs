<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Paperformat Definition -->
    <record id="paperformat_sale_quotation" model="report.paperformat">
        <field name="name">Sale Quotation</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">30</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action -->
    <record id="action_sale_quotation" model="ir.actions.report">
        <field name="name">Sale Quotation</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">aptus_macrofix_customizations.report_sale_quotation</field>
        <field name="report_file">aptus_macrofix_customizations.report_sale_quotation</field>
        <field name="print_report_name">(object.state in ('draft', 'sent') and 'Quotation - %s' % (object.name)) or 'Order - %s' % (object.name)</field>
<!--        <field name="print_report_name">object.with_context('is_pro_forma', False) and 'Pro-Forma Invoice - %s' % object.name or (object.state in ('draft', 'sent') and 'Quotation - %s' % object.name) or 'Order - %s' % object.name</field>-->
        <field name="binding_type">report</field>
        <field name="binding_model_id" search="[('model','=','sale.order')]"/>
        <field name="paperformat_id" ref="aptus_macrofix_customizations.paperformat_sale_quotation"/>
    </record>

<!--    hiding default report action-->

<!--    <record id="con_construction_base.action_report_saleorder_cons" model="ir.actions.report">-->
<!--        <field name="binding_model_id" eval="False"/>-->
<!--        <field name="binding_type">report</field>-->
<!--    </record>-->

    <record id="sale_pdf_quote_builder.action_report_saleorder_raw" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
        <field name="binding_type">report</field>
    </record>

    <record id="sale.action_report_saleorder" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
        <field name="binding_type">report</field>
    </record>

    <record id="sale.action_report_pro_forma_invoice" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
        <field name="binding_type">report</field>
    </record>

    <record id="sale_timesheet.timesheet_report_sale_order" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
        <field name="binding_type">report</field>
    </record>

<!--    /hiding default report action-->

    <!-- Main Template -->
    <template id="report_sale_quotation">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="o">
                    <t t-set="company" t-value="o.company_id.sudo()"/>
                    <t t-call="aptus_macrofix_customizations.report_sale_quotation_main" t-lang="o.partner_id.lang"/>
                </t>
            </t>
        </t>
    </template>

    <!-- Body Template -->
    <template id="report_sale_quotation_main">
        <!-- Header -->
        <!-- <header>-->
            <div style="border-top: 1px solid; border-right: 1px solid; border-left: 1px solid; padding: 8px">
                <div class="row" style="padding-bottom: 16px">
                    <div class="col-4">
                        <img t-attf-src="data:image/*;base64,{{company.logo}}" t-att-alt="company.name"
                             style="height: 80px; width:250px;"/>
                    </div>

                    <div class="col-4" style="padding-top: 24px; padding-left: 65px;">
                        <h4>
                            <u>
                                <t t-if="env.context.get('proforma', False) or is_pro_forma">
                                    Pro-Forma Invoice</t>
                                <t t-elif="o.state in ['draft', 'sent']">
                                    Sales Quotation
                                </t>
                                <t t-else="">
                                    Sales Order
                                </t>
                            </u>
                        </h4>
                    </div>

                    <div class="col-4" style="text-align: right">
                        <div style="font-size: 20px;">VATIN: <span style="font-size:19px;"><t t-esc="company.vat"/></span> </div>
                        <div style="font-size: 20px; margin-top: 10px;"><span style="font-size:19px;">CR NO: 1029080</span></div>
                    </div>
                </div>
                <div class="row" style="padding: 8px; padding: 8px">
                    <div class="col-6">
<!--                        <span t-raw="company.contact_address.replace('\n', '&lt;br/&gt;')"/>-->
                        <t t-if="company.parent_id">
                            <strong><t t-esc="company.parent_id.name"/></strong>
                        </t>
                        <t t-else="">
                            <strong><t t-esc="company.name"/></strong>
                        </t>  
                        <br/>
                        <t t-esc="company.street"/>,
                        <br/>
                        <t t-esc="company.street2"/>,
                        <t t-esc="company.city"/>,
                        <t t-esc="company.state_id.name"/>,
                        <t t-esc="company.country_id.name"/>.
                        <br/>
                        <span>Telephone: <t t-esc="company.phone"/> </span>
                        <br/>
                        <span>Email: <t t-esc="company.email"/> </span>
                    </div>
                    <div class="col-6" style="text-align: right;">
<!--                        <t t-esc="o.name"/>-->
                        <h4 class="mt-4" style="background-color: rgb(211, 227, 253);text-align: center">
                            <span t-if="env.context.get('proforma', False) or is_pro_forma">Pro-Forma Invoice # </span>
                            <span t-elif="o.state in ['draft','sent']">Quotation # </span>
                            <span t-else="">Order # </span>
                            <br/>
                            <span t-field="o.name">SO0000</span>
                        </h4>
                    </div>
                </div>
            </div>
<!--        </header>-->

        <!-- Body -->
        <div class="main" style="border-bottom: 1px solid; border-right: 1px solid; border-left: 1px solid; padding: 8px">
            <div class="page">
                <div class="row col-12" style="background-color: rgb(211, 227, 253)">
                    <div class="col-6" style="padding: 8px;">
                        <span>Date: <t t-esc="o.date_order.strftime('%d-%m-%Y')"/></span> <br/>
                        <span>Sales Person: <t t-esc="o.user_id.name"/></span> <br/>
                        <span>Ph No: <t t-esc="o.user_id.phone"/></span> <br/>
                        <span>Email: <t t-esc="o.user_id.email"/></span>

                    </div>

                    <div class="col-6" style="padding: 8px;">
                        <span style="display: inline-block; min-width: 140px;">Payment Terms</span>
                        <span>:</span>
                        <span><t t-esc="o.payment_term_id.name"/></span>
                        <br/>

                        <span style="display: inline-block; min-width: 140px;">Validity</span>
                        <span>:</span>
                        <span><t t-esc="o.validity_date.strftime('%d-%m-%Y')"/></span>
                        <br/>

                        <span style="display: inline-block; min-width: 140px;">Delivery</span>
                        <span>:</span>
                        <span><t t-esc="o.delivery"/></span>
                    </div>
                </div>

<!--                <hr style="color: #000000; height: 2px; width: 98%;margin-left: 8px;"/>-->

                <div class="row">
                    <div class="col-6" style="padding-left: 8px; padding-right: 8px;"> <!--8px 8px 8px 130px-->
                        <span>Customer Address:</span> <br/>
<!--                        <span t-raw="o.partner_invoice_id.contact_address.replace('\n', '&lt;br/&gt;')"/>-->

                        <span t-if="o.partner_invoice_id.name">
                            <t t-esc="o.partner_invoice_id.name"/>
                        </span>
                        <br t-if="o.partner_invoice_id.name"/>

                        <span t-if="o.partner_invoice_id.street">
                            <t t-esc="o.partner_invoice_id.street"/>
                        </span>
                        <br t-if="o.partner_invoice_id.street"/>

                        <span t-if="o.partner_invoice_id.street2">
                            <t t-esc="o.partner_invoice_id.street2"/>
                        </span>
                        <br t-if="o.partner_invoice_id.street2"/>

                        <span t-if="o.partner_invoice_id.city">
                            <t t-esc="o.partner_invoice_id.city"/>
                        </span>

                        <span t-if="o.partner_invoice_id.state_id">
                            <t t-esc="o.partner_invoice_id.state_id.name"/>
                        </span>

                        <span t-if="o.partner_invoice_id.zip">
                            - <t t-esc="o.partner_invoice_id.zip"/>,
                        </span>
                        <span t-if="o.partner_invoice_id.country_id">
                            <t t-esc="o.partner_invoice_id.country_id.name"/>
                        </span>

                    </div>
                    <div class="col-6" style="padding-left: 8px; padding-right: 8px;"> <!--8px 8px 8px 130px-->
                        <span>Shipping Address:</span> <br/>
<!--                            <span t-raw="o.partner_shipping_id.contact_address.replace('\n', '&lt;br/&gt;')"/>-->

                        <span t-if="o.partner_shipping_id.name">
                            <t t-esc="o.partner_shipping_id.name"/>
                        </span>
                        <br t-if="o.partner_shipping_id.name"/>

                        <span t-if="o.partner_shipping_id.street">
                            <t t-esc="o.partner_shipping_id.street"/>
                        </span>
                        <br t-if="o.partner_shipping_id.street"/>

                        <span t-if="o.partner_shipping_id.street2">
                            <t t-esc="o.partner_shipping_id.street2"/>
                        </span>
                        <br t-if="o.partner_shipping_id.street2"/>

                        <span t-if="o.partner_shipping_id.city">
                            <t t-esc="o.partner_shipping_id.city"/>
                        </span>

                        <span t-if="o.partner_shipping_id.state_id">
                            , <t t-esc="o.partner_shipping_id.state_id.name"/>
                        </span>

                        <span t-if="o.partner_shipping_id.zip">
                            - <t t-esc="o.partner_shipping_id.zip"/>,
                        </span>

                        <span t-if="o.partner_shipping_id.country_id">
                            <t t-esc="o.partner_shipping_id.country_id.name"/>
                        </span>

                    </div>
                </div>

<!--                <hr style="color: #000000; height: 2px; width: 98%;margin-left: 8px;"/>-->

                <div class="row">
                    <table class="table" style="width:100%; border-collapse: collapse; padding: 8px">
                        <thead style="padding-top:16px">
                           <t t-set="currency" t-value="o.pricelist_id.currency_id"/>
                            <tr style="background-color: rgb(211, 227, 253); font-size:14px;">
                                <th>Sr.</th>
                                <th>Part No</th>
                                <th>Description</th>
                                <th>UoM</th>
                                <th>Qty</th>
                                <th>Unit Price</th>
                                <th>Discount %</th>
<!--                                <th>Taxes</th>-->
                                <th>
                                    Amount
                                    <t t-esc="currency.symbol"/>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="sno" t-value="1"/>
                            <t t-foreach="o.order_line" t-as="line">
                                <tr style="font-size:13px;">
                                    <!-- Serial number -->
                                    <t t-if="line.display_type not in ['line_section', 'line_note']">
                                        <td style="text-align:center;">
                                            <t t-esc="sno"/>
                                            <t t-set="sno" t-value="sno + 1"/>
                                        </td>
                                        <td><span t-field="line.product_id.default_code"/></td>
                                        <td><span t-field="line.name"/></td>
                                        <td><span t-field="line.product_uom_id.name"/></td>
                                        <td style="text-align:right;"><span t-field="line.product_uom_qty"/></td>
                                        <td style="text-align:right;"><span t-field="line.price_unit"/></td>
                                        <td style="text-align:right;"><span t-field="line.discount"/></td>
                                        <td style="text-align:right;"><span t-field="line.price_subtotal"/></td>
                                    </t>
                                    <t t-elif="line.display_type == 'line_section'">
                                        <td colspan="8" style="padding-left:15px;font-weight:bold; background:#f0f0f0;">
                                            <span t-field="line.name"/>
                                        </td>
                                    </t>
                                    <t t-elif="line.display_type == 'line_note'">
                                        <td colspan="8" style="font-style:italic;padding-left:15px;">
                                            <span t-field="line.name"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <div class="row" style="margin-top: -10px; margin-bottom: -10px; font-size: 12px">
                    <!--Totals-->
                    <div style="width: 50%;">
                        <!--  <strong>Total in Words:</strong>-->
                        <!--  <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>-->
                    </div>

                    <table class="table col-6" style="width: 50%; border-collapse: collapse;">
                        <tbody>
                           <t t-set="currency" t-value="o.pricelist_id.currency_id"/>

                            <tr>
                                <td><strong>Subtotal</strong></td>
                                <td style="text-align: right;">
                                    <t t-esc=" ('%.3f' % o.amount_untaxed)"/>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>5% VAT</strong></td>
                                <td style="text-align: right;">
                                    <t t-esc="('%.3f' % o.amount_tax)"/>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Grand Total</strong></td>
                                <td style="text-align: right;">
                                    <t t-esc="o.currency_id.symbol + ' ' + ('%.3f' % o.amount_total)"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                </div>

                <div class="row">
                    <div class="col-12" style="margin-top: -6px; margin-bottom: -10px;font-size: 12px;">
                        <strong>Total in Words:</strong>
                         <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
<!--                        <t t-set="amount_text" t-value="o.currency_id.amount_to_text(o.amount_total)"/>-->
<!--                        <t t-esc="'Omani Riyal ' + amount_text.replace('Riyals', '').strip() + ' Only'"/>-->
                    </div>
                </div>

                <hr style="color: #000000; height: 2px; width: 98%;margin-left: 8px;"/>

                <div class="row" style="margin-top: -10px;">
                    <span><b>Terms</b> <b>&amp;</b> <b>Conditions</b></span>
                </div>

                <div>
                    <div class="col-12" style="font-size: 12px">
                        <t t-esc="o.note"/>
                    </div>
                </div>

               <div class="row" style="page-break-inside: avoid !important; width: 100%; display: flex; box-sizing: border-box;">
                    <!-- Empty Section 1 -->
                   <div style="width: 45%"></div>

                    <!--<div style="width: 45%; border-right: 1px solid #000000">
                        <span><b>Terms</b> <b>&amp;</b> <b>Conditions</b></span>
                        <div class="col-12" style="font-size: 12px">
                            <t t-esc="o.note"/>
                        </div>
                    </div>-->

                    <!-- Stamp Section -->
                    <div style="width: 25%; box-sizing: border-box;">
                        <t t-if="o.stamp_selection == 'oriental_oryx_stamp' and o.company_id.oriental_oryx_stamp">
                            <img t-att-src="'data:image/png;base64,%s' % o.company_id.oriental_oryx_stamp.decode('utf-8')"
                                 style="max-height:120px;margin-top: 34px; margin-left: 37px"/>
                        </t>
                        <t t-if="o.stamp_selection == 'aptus_stamp' and o.company_id.aptus_stamp">
                            <img t-att-src="'data:image/png;base64,%s' % o.company_id.aptus_stamp.decode('utf-8')"
                                 style="max-height:120px;margin-top: 34px; margin-left: 37px"/>
                        </t>
                    </div>

                    <!-- Signature Section -->
                    <div style="width: 30%; padding: 10px; box-sizing: border-box; text-align: center;">
                       <t t-if="company.parent_id">
                            <strong>For <t t-esc="company.parent_id.name"/></strong>
                        </t>
                        <t t-else="">
                            <strong>For <t t-esc="company.name"/></strong>
                        </t>
                       <br/>
                        <t t-if="o.sudo().user_id.sign_signature">
                            <img t-att-src="'data:image/png;base64,%s' % o.sudo().user_id.sign_signature.decode('utf-8')" style="max-height: 80px; max-width: 100%; margin: 5px 0;" />
                        </t>
                        <div>
                            <span t-esc="o.sudo().user_id.signature"/>
                        </div>
<!--                        <div>-->
<!--                            <span t-esc="o.sudo().user_id.employee_id.department_id.name"/>-->
<!--                        </div>-->
                        <b>Authorised Signatory</b>
                    </div>
                </div>
            </div>
        </div>

         <!--Footer-->
        <footer>
            <div class="footer" style="margin-top: 20px; font-size:10px; text-align:center; border-top:1px solid black; padding-top:5px;">
                <div>
                    <span>Email: <t t-esc="company.email"/> | Website: <t t-esc="company.website"/></span>
                </div>
                <div>
                    <strong>Page <span class="page"/> of <span class="topage"/></strong>
                </div>
            </div>
        </footer>
    </template>
</odoo>
