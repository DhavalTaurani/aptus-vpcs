<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="view_company_form_inherit">
        <field name="name">res.company.form.inherit</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="model">res.company</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <separator string="Company Stamps" colspan="2"/>
                <field name="oriental_oryx_stamp" widget="image" class="oe_avatar"/>
                <field name="aptus_stamp" widget="image" class="oe_avatar"/>
            </xpath>
        </field>
    </record>
</odoo>
