<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_work_credit_in_invoice" model="ir.ui.view">
        <field name="name">account.move.view.inherited</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <label for="ref" position="attributes">
                <attribute name="string">Invoice Reference</attribute>
            </label>
            <xpath expr="//group[@id='header_right_group']/label[@for='invoice_date'][2]" position="attributes">
                <attribute name="string">Invoice Date</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']/list/field[@name='account_id']" position="after">
                <field name="inst_type" optional="hide"/>
                <field name="inst_no" optional="hide"/>
            </xpath>
        </field>
     </record>

