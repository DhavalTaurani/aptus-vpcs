<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="mfx_purchase_order_veiw" model="ir.ui.view">
            <field name="name">purchase.order.template.form.inherit</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="model">purchase.order</field>
            <field name="arch" type="xml">
                <xpath expr="//sheet/group/group/div[@name='reminder']" position="after">
                    <field name="stamp_selection"/>
                </xpath>
                <xpath expr="//field[@name='fiscal_position_id']" position="after">
                    <field name="delivery_terms" />
                    <field name="customer_id" options="{'no_create': True, 'no_create_edit': True}" domain="[('is_company', '=', True)]"/>
                    <field name="customer_contact_id" domain="[('parent_id', '=', customer_id)]" options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="customer_contact_email"/>
                    <field name="customer_contact_phone"/>
                    <field name="remarks"/>
                    <field name="rel_sales_order" options="{'no_create': True, 'no_create_edit': True}" domain="['|', ('partner_id.parent_id', '=', customer_id), ('partner_id', '=', customer_id)]"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>