            <field name="prefix">SO/SLR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="4" />
        </record>

        <record id="seq_sale_order_sgi" model="ir.sequence">
            <field name="name">Sale Order - SGI</field>
            <field name="code">sale.order.sgi</field>
            <field name="prefix">SO/SGI/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="5" />
